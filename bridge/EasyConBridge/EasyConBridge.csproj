<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>EasyConBridge</AssemblyName>
  </PropertyGroup>

  <PropertyGroup>
    <EasyConSourceRoot Condition="'$(EasyConSourceRoot)' == ''">$(MSBuildThisFileDirectory)..\..\third_party\EasyCon</EasyConSourceRoot>
  </PropertyGroup>

  <ItemGroup Condition="Exists('$(EasyConSourceRoot)\src\EasyCon.Core\EasyCon.Core.csproj')">
    <ProjectReference Include="$(EasyConSourceRoot)\src\EasyCon.Core\EasyCon.Core.csproj" />
  </ItemGroup>
</Project>
